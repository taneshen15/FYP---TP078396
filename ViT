#library imports
import os
import time
import numpy as np
import matplotlib.pyplot as plt

import torch
import torch.nn as nn
import torch.optim as optim

from torchvision import datasets, transforms
from torchvision.models import vit_b_16, ViT_B_16_Weights
from torch.utils.data import DataLoader

from sklearn.metrics import (
    accuracy_score,
    classification_report,
    confusion_matrix,
    ConfusionMatrixDisplay
)
#cpu/gpu check
device = torch.device(
    "cuda" if torch.cuda.is_available() else "cpu"
)

print("Using device:", device)

if torch.cuda.is_available():
    print("GPU:", torch.cuda.get_device_name(0))

#google drive mount and dataset path
from google.colab import drive

drive.mount("/content/drive")

dataset_path = "/content/drive/MyDrive/FYP/final_dataset"

#image transform and dataset load (same as CNN)
train_transform = transforms.Compose([
    transforms.Resize((224, 224)),
    transforms.RandomHorizontalFlip(),
    transforms.RandomRotation(10),
    transforms.ToTensor(),
    transforms.Normalize(
        mean=[0.485, 0.456, 0.406],
        std=[0.229, 0.224, 0.225]
    )
])

evaluation_transform = transforms.Compose([
    transforms.Resize((224, 224)),
    transforms.ToTensor(),
    transforms.Normalize(
        mean=[0.485, 0.456, 0.406],
        std=[0.229, 0.224, 0.225]
    )
])

train_dataset = datasets.ImageFolder(
    os.path.join(dataset_path, "train"),
    transform=train_transform
)

val_dataset = datasets.ImageFolder(
    os.path.join(dataset_path, "val"),
    transform=evaluation_transform
)

test_dataset = datasets.ImageFolder(
    os.path.join(dataset_path, "test"),
    transform=evaluation_transform
)

#dataloaders (batch of 16)
batch_size = 16

train_loader = DataLoader(
    train_dataset,
    batch_size=batch_size,
    shuffle=True,
    num_workers=2,
    pin_memory=torch.cuda.is_available()
)

val_loader = DataLoader(
    val_dataset,
    batch_size=batch_size,
    shuffle=False,
    num_workers=2,
    pin_memory=torch.cuda.is_available()
)

test_loader = DataLoader(
    test_dataset,
    batch_size=batch_size,
    shuffle=False,
    num_workers=2,
    pin_memory=torch.cuda.is_available()
)

#dataset check
print("Classes:", train_dataset.classes)
print("Class mapping:", train_dataset.class_to_idx)

print("Training images:", len(train_dataset))
print("Validation images:", len(val_dataset))
print("Testing images:", len(test_dataset))

#model training
from torchvision.models import vit_b_16, ViT_B_16_Weights

weights = ViT_B_16_Weights.DEFAULT

vit_model = vit_b_16(weights=weights)

print(vit_model.heads)

#changing classification head
import torch.nn as nn

num_classes = 4

in_features = vit_model.heads.head.in_features

vit_model.heads.head = nn.Linear(
    in_features,
    num_classes
)

vit_model = vit_model.to(device)

print(vit_model.heads)

#freezing pretrained layers
for param in vit_model.parameters():
    param.requires_grad = False

for param in vit_model.heads.parameters():
    param.requires_grad = True

#verify parameters
trainable_params = sum(
    p.numel()
    for p in vit_model.parameters()
    if p.requires_grad
)

total_params = sum(
    p.numel()
    for p in vit_model.parameters()
)

print(f"Trainable parameters: {trainable_params:,}")
print(f"Total parameters: {total_params:,}")

#optimizer and loss function
criterion = nn.CrossEntropyLoss()

optimizer = optim.Adam(
    vit_model.heads.parameters(),
    lr=0.001
)
#learning rate scheduler
scheduler = optim.lr_scheduler.StepLR(
    optimizer,
    step_size=5,
    gamma=0.1
)
#metrics
vit_train_losses = []
vit_train_accuracies = []

vit_val_losses = []
vit_val_accuracies = []

#training loop
import time
import torch

num_epochs = 20
best_vit_accuracy = 0.0

save_path = "/content/drive/MyDrive/FYP/best_vit_b16.pth"

start_time = time.time()

for epoch in range(num_epochs):

    epoch_start_time = time.time()

    print(f"\nEpoch {epoch + 1}/{num_epochs}")
    print("-" * 40)

vit_model.train()

    running_train_loss = 0.0
    running_train_correct = 0
    train_total = 0

    for images, labels in train_loader:

        images = images.to(device)
        labels = labels.to(device)

        #clear previous gradients
        optimizer.zero_grad()

        outputs = vit_model(images)

        #loss calc
        loss = criterion(outputs, labels)

        #backpropagation
        loss.backward()

        #update the classification head
        optimizer.step()

        #combine traiing loss
        running_train_loss += loss.item() * images.size(0)

        #da predictions
        _, predicted = torch.max(outputs, 1)

        running_train_correct += (predicted == labels).sum().item()
        train_total += labels.size(0)

    #calc final training metrics
    train_loss = running_train_loss / train_total
    train_accuracy = running_train_correct / train_total

    vit_train_losses.append(train_loss)
    vit_train_accuracies.append(train_accuracy)
 vit_model.eval()

    running_val_loss = 0.0
    running_val_correct = 0
    val_total = 0

    with torch.no_grad():

        for images, labels in val_loader:

            images = images.to(device)
            labels = labels.to(device)

            # Forward pass
            outputs = vit_model(images)

            # Calculate validation loss
            loss = criterion(outputs, labels)

            running_val_loss += loss.item() * images.size(0)

            # Get predictions
            _, predicted = torch.max(outputs, 1)

            running_val_correct += (predicted == labels).sum().item()
            val_total += labels.size(0)

    # Calculate validation metrics
    val_loss = running_val_loss / val_total
    val_accuracy = running_val_correct / val_total

    vit_val_losses.append(val_loss)
    vit_val_accuracies.append(val_accuracy)

 epoch_time = time.time() - epoch_start_time

    print(f"Training Loss:       {train_loss:.4f}")
    print(f"Training Accuracy:   {train_accuracy:.4f}")
    print(f"Validation Loss:     {val_loss:.4f}")
    print(f"Validation Accuracy: {val_accuracy:.4f}")
    print(f"Learning Rate:       {optimizer.param_groups[0]['lr']:.6f}")
    print(f"Epoch Time:          {epoch_time:.2f} seconds")

 if val_accuracy > best_vit_accuracy:

        best_vit_accuracy = val_accuracy

        torch.save(
            vit_model.state_dict(),
            save_path
        )

        print(
            f"✅ Best ViT model saved "
            f"with validation accuracy: {best_vit_accuracy:.4f}"
        )

    # Update learning rate
    scheduler.step()

total_training_time = time.time() - start_time

print("\n" + "=" * 45)
print("ViT training completed!")
print(f"Best Validation Accuracy: {best_vit_accuracy:.4f}")
print(f"Total Training Time: {total_training_time / 60:.2f} minutes")
print(f"Best model saved at: {save_path}")
print("=" * 45)

