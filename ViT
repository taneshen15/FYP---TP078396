#loading best saved model

from torchvision.models import vit_b_16, ViT_B_16_Weights
import torch.nn as nn
import torch

#ViT-B/16 architecture
weights = ViT_B_16_Weights.DEFAULT
best_vit_model = vit_b_16(weights=None)

# Replace classification head with 4 output classes
best_vit_model.heads.head = nn.Linear(
    best_vit_model.heads.head.in_features,
    len(train_dataset.classes)
)

# Load best saved weights
best_vit_model.load_state_dict(
    torch.load(
        "/content/drive/MyDrive/FYP/best_vit_b16.pth",
        map_location=device
    )
)

best_vit_model = best_vit_model.to(device)
best_vit_model.eval()

print("Best ViT model loaded successfully!")

#testing model on test set

from sklearn.metrics import accuracy_score

vit_all_predictions = []
vit_all_labels = []

with torch.no_grad():

    for images, labels in test_loader:

        images = images.to(device)
        labels = labels.to(device)

        outputs = best_vit_model(images)

        _, predicted = torch.max(outputs, 1)

        vit_all_predictions.extend(predicted.cpu().numpy())
        vit_all_labels.extend(labels.cpu().numpy())

vit_test_accuracy = accuracy_score(
    vit_all_labels,
    vit_all_predictions
)

print(f"ViT Test Accuracy: {vit_test_accuracy * 100:.2f}%")

#print performance metrics

from sklearn.metrics import classification_report

vit_report = classification_report(
    vit_all_labels,
    vit_all_predictions,
    target_names=train_dataset.classes
)

print(vit_report)

